rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validId(id) {
      return id is string
        && id.size() > 0
        && id.size() < 160
        && id.matches('^[A-Za-z0-9_\\-]+$');
    }

    function vendorPath(vendorId) {
      return /databases/$(database)/documents/vendors/$(vendorId);
    }

    function vendorUserPath() {
      return /databases/$(database)/documents/vendorUsers/$(request.auth.uid);
    }

    function vendorExists(vendorId) {
      return validId(vendorId) && exists(vendorPath(vendorId));
    }

    function vendorExistsAfter(vendorId) {
      return validId(vendorId) && existsAfter(vendorPath(vendorId));
    }

    function signedInEmail() {
      return request.auth.token.email is string ? request.auth.token.email : '';
    }

    function ownerFromVendorDoc(vendorId) {
      return signedIn()
        && vendorExists(vendorId)
        && get(vendorPath(vendorId)).data.ownerUid == request.auth.uid;
    }

    function ownerFromVendorDocAfter(vendorId) {
      return signedIn()
        && vendorExistsAfter(vendorId)
        && getAfter(vendorPath(vendorId)).data.ownerUid == request.auth.uid;
    }

    function activeMemberStatus(status) {
      return status in ['active', 'Active'];
    }

    function hasVendorUser(vendorId) {
      return signedIn()
        && validId(vendorId)
        && exists(vendorUserPath())
        && get(vendorUserPath()).data.vendorId == vendorId
        && activeMemberStatus(get(vendorUserPath()).data.status);
    }

    function isOwner(vendorId) {
      return hasVendorUser(vendorId) && get(vendorUserPath()).data.role == 'Owner';
    }

    function isActiveVendorUser(vendorId) {
      return hasVendorUser(vendorId);
    }

    function isManager(vendorId) {
      return isOwner(vendorId)
        || (hasVendorUser(vendorId) && get(vendorUserPath()).data.role in ['Admin', 'Manager']);
    }

    function staffPath(staffId) {
      return /databases/$(database)/documents/staff/$(staffId);
    }

    function recordStaffId(data) {
      return data.staffId is string
        ? data.staffId
        : data.createdBy is string
          ? data.createdBy
          : data.requestedByStaffId is string
            ? data.requestedByStaffId
            : data.requestedBy is string
              ? data.requestedBy
              : data.receivedBy is string
                ? data.receivedBy
                : data.receivedByStaffId is string
                  ? data.receivedByStaffId
                  : data.createdByStaffId is string
                    ? data.createdByStaffId
                    : data.assignedByStaffId is string
                      ? data.assignedByStaffId
                      : data.confirmedByStaffId is string
                        ? data.confirmedByStaffId
                        : data.deliveryStaffId is string
                          ? data.deliveryStaffId
                          : data.receivingStaffId is string
                            ? data.receivingStaffId
                            : data.reportedBy is string
                              ? data.reportedBy
                              : data.inspectedBy is string
                                ? data.inspectedBy
                                : data.allocatedBy is string
                                  ? data.allocatedBy
                                  : data.generatedBy is string
                                    ? data.generatedBy
                                  : data.openedBy is string
                                    ? data.openedBy
                                    : data.recordedBy is string
                                      ? data.recordedBy
                                      : data.updatedByStaffId is string
                                        ? data.updatedByStaffId
                                        : data.updatedBy is string
                                          ? data.updatedBy
                                          : data.reviewedBy is string
                                            ? data.reviewedBy
                                            : data.paidBy is string
                                              ? data.paidBy
                                              : '';
    }

    function isActiveStaff(vendorId, staffId) {
      return isOwner(vendorId)
        || (
          staffId is string
          && validId(staffId)
          && exists(staffPath(staffId))
          && get(staffPath(staffId)).data.vendorId == vendorId
          && activeMemberStatus(get(staffPath(staffId)).data.status)
        );
    }

    function hasPermission(vendorId, permission) {
      return isOwner(vendorId)
        || (
          hasVendorUser(vendorId)
          && get(vendorUserPath()).data.permissions is list
          && get(vendorUserPath()).data.permissions.hasAny(['*', permission])
        );
    }

    function hasActiveStaffForRecord(vendorId, data) {
      return isActiveStaff(vendorId, recordStaffId(data));
    }

    function canCreateForVendor(vendorId) {
      return isActiveVendorUser(vendorId);
    }

    function canManageCreatedVendor(vendorId) {
      return isManager(vendorId);
    }

    function createForVendor(vendorId) {
      return signedIn()
        && request.resource.data.vendorId == vendorId
        && canCreateForVendor(vendorId);
    }

    function createForVendorStaff(vendorId) {
      return createForVendor(vendorId)
        && hasActiveStaffForRecord(vendorId, request.resource.data);
    }

    function updateForSameVendor(vendorId) {
      return signedIn()
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == vendorId
        && isActiveVendorUser(vendorId);
    }

    function updateForSameVendorStaff(vendorId) {
      return updateForSameVendor(vendorId)
        && hasActiveStaffForRecord(vendorId, request.resource.data);
    }

    function shiftClosedStatus(status) {
      return status in ['Closed', 'Force Closed', 'Locked'];
    }

    function cashMovementRestricted(data) {
      return data.movementType in ['CASH_OUT', 'PETTY_CASH', 'SAFE_DROP', 'BANK_DEPOSIT', 'FLOAT_ADJUSTMENT', 'VARIANCE_ADJUSTMENT', 'REVERSAL']
        || (data.movementType == 'CASH_REFUND' && data.amount > 100)
        || (data.movementType == 'OPENING_FLOAT' && data.amount > 500);
    }

    function cashMovementApprovedOrAllowed(data) {
      return !cashMovementRestricted(data)
        || data.approvalStatus in ['Approved', 'Pending']
        || hasPermission(data.vendorId, 'cashControl.approve')
        || hasPermission(data.vendorId, 'approvals.approve');
    }

    function lockedBusinessDayImmutable() {
      return resource.data.status != 'Locked'
        || (
          isManager(resource.data.vendorId)
          && request.resource.data.status == 'Reopened'
          && request.resource.data.businessDayId == resource.data.businessDayId
          && request.resource.data.vendorId == resource.data.vendorId
          && request.resource.data.branchId == resource.data.branchId
          && request.resource.data.businessDate == resource.data.businessDate
        );
    }

    function goodsReceiptPostedImmutable() {
      return !(
          resource.data.postingStatus == 'Posted'
          || resource.data.receivingStatus in ['Posted', 'Partially Posted']
          || resource.data.status in ['Posted', 'Partially Posted']
        )
        || (
          request.resource.data.vendorId == resource.data.vendorId
          && request.resource.data.goodsReceiptId == resource.data.goodsReceiptId
          && request.resource.data.supplierId == resource.data.supplierId
          && request.resource.data.purchaseOrderId == resource.data.purchaseOrderId
          && request.resource.data.subtotal == resource.data.subtotal
          && request.resource.data.vatTotal == resource.data.vatTotal
          && request.resource.data.total == resource.data.total
          && request.resource.data.postingStatus == resource.data.postingStatus
        );
    }

    function inventoryMovementIsValid(data, movementId) {
      return data.movementId == movementId
        && data.vendorId is string
        && data.branchId is string
        && data.warehouseId is string
        && data.productId is string
        && data.movementType in [
          'OPENING_BALANCE',
          'GOODS_RECEIVED',
          'SALE',
          'SALES_RETURN',
          'PURCHASE_RETURN',
          'TRANSFER_OUT',
          'TRANSFER_IN',
          'STOCKTAKE_ADJUSTMENT',
          'DAMAGE_WRITEOFF',
          'EXPIRY_WRITEOFF',
          'THEFT_LOSS',
          'MANUAL_CORRECTION',
          'PRODUCTION_IN',
          'PRODUCTION_OUT',
          'REVERSAL'
        ]
        && data.quantityIn is number
        && data.quantityOut is number
        && data.quantityIn >= 0
        && data.quantityOut >= 0
        && !(data.quantityIn > 0 && data.quantityOut > 0)
        && (data.quantityIn > 0 || data.quantityOut > 0)
        && data.balanceBefore is number
        && data.balanceAfter is number
        && data.balanceAfter == data.balanceBefore + data.quantityIn - data.quantityOut
        && data.referenceType is string
        && data.referenceId is string;
    }

    function inventoryBalanceIsValid(data, balanceId) {
      return data.balanceId == balanceId
        && data.vendorId is string
        && data.branchId is string
        && data.warehouseId is string
        && data.productId is string
        && data.quantityOnHand is number
        && data.quantityReserved is number
        && data.quantityAvailable is number
        && data.quantityInTransit is number
        && data.quantityAvailable == data.quantityOnHand - data.quantityReserved;
    }

    function balanceRebuildAllowed(vendorId) {
      return isManager(vendorId)
        || hasPermission(vendorId, 'inventory.rebuildBalance')
        || hasPermission(vendorId, 'inventory.balance.rebuild');
    }

    function stocktakeEditable() {
      return !(resource.data.status in ['Posted', 'Closed'])
        || (
          request.resource.data.status == resource.data.status
          && request.resource.data.vendorId == resource.data.vendorId
          && request.resource.data.stocktakeId == resource.data.stocktakeId
        );
    }

    function transferEditable() {
      return !(resource.data.status in ['Completed', 'Fully Received', 'Closed With Outstanding', 'Cancelled'])
        || isManager(resource.data.vendorId)
        || hasPermission(resource.data.vendorId, 'stockTransfers.reopen');
    }

    function highRiskAdjustmentAllowed(vendorId, data) {
      return !(data.riskLevel in ['High', 'Critical'] || data.approvalRequired == true)
        || hasPermission(vendorId, 'inventory.approveAdjustment')
        || hasPermission(vendorId, 'approvals.approve')
        || isManager(vendorId);
    }

    function returnReferencesAccessibleReceipt(data) {
      return data.goodsReceiptId is string
        && exists(/databases/$(database)/documents/goods_receipts/$(data.goodsReceiptId))
        && get(/databases/$(database)/documents/goods_receipts/$(data.goodsReceiptId)).data.vendorId == data.vendorId;
    }

    function customerCreditApprovalAllowed(vendorId) {
      return isManager(vendorId)
        || hasPermission(vendorId, 'customers.credit.approve')
        || hasPermission(vendorId, 'approvals.approve');
    }

    function customerCreditBlockAllowed(vendorId) {
      return isManager(vendorId)
        || hasPermission(vendorId, 'customers.credit.block')
        || hasPermission(vendorId, 'customers.credit.approve');
    }

    function customerAdjustmentAllowed(vendorId) {
      return isManager(vendorId)
        || hasPermission(vendorId, 'customers.adjust')
        || hasPermission(vendorId, 'approvals.approve');
    }

    function customerWriteOffAllowed(vendorId) {
      return isOwner(vendorId)
        || hasPermission(vendorId, 'customers.writeoff')
        || hasPermission(vendorId, 'approvals.approve');
    }

    function customerCreditApplicationIdMatches(id, data) {
      return data.creditApplicationId == id || data.applicationId == id;
    }

    function customerPaymentIdMatches(id, data) {
      return data.customerPaymentId == id || data.paymentId == id;
    }

    function postedPaymentMutable() {
      return !(
        resource.data.status in ['Posted', 'Synchronized']
        || resource.data.postingStatus == 'Posted'
      );
    }

    function statementSnapshotMutable() {
      return resource.data.status != 'Issued';
    }

    function supplierPaymentAllowed(vendorId) {
      return isManager(vendorId)
        || hasPermission(vendorId, 'supplierPayments.create')
        || hasPermission(vendorId, 'supplierPayments.manage');
    }

    function supplierPaymentApprovalAllowed(vendorId) {
      return isManager(vendorId)
        || hasPermission(vendorId, 'supplierPayments.manage')
        || hasPermission(vendorId, 'approvals.approve');
    }

    function supplierAdjustmentAllowed(vendorId) {
      return isManager(vendorId)
        || hasPermission(vendorId, 'supplierAccounts.adjust')
        || hasPermission(vendorId, 'supplierReturns.approve')
        || hasPermission(vendorId, 'approvals.approve');
    }

    function supplierPaymentIdMatches(id, data) {
      return data.supplierPaymentId == id || data.paymentId == id;
    }

    function supplierPaymentMutable() {
      return !(
        resource.data.status in ['Paid', 'Posted', 'Reversed']
        || resource.data.approvalStatus in ['Approved', 'Rejected']
      );
    }

    function supplierReconciliationMutable() {
      return resource.data.status != 'Approved';
    }

    function deliveryStatusFinal(status) {
      return status in ['Completed', 'Cancelled'];
    }

    function deliveryPermission(vendorId, permission) {
      return isManager(vendorId) || hasPermission(vendorId, permission);
    }

    function deliveryMutationAllowed(vendorId) {
      return deliveryPermission(vendorId, 'delivery.create')
        || deliveryPermission(vendorId, 'delivery.assign')
        || deliveryPermission(vendorId, 'delivery.dispatch')
        || deliveryPermission(vendorId, 'delivery.track')
        || deliveryPermission(vendorId, 'delivery.verifyCode')
        || deliveryPermission(vendorId, 'delivery.complete')
        || deliveryPermission(vendorId, 'delivery.cancel')
        || deliveryPermission(vendorId, 'delivery.collectCash')
        || deliveryPermission(vendorId, 'delivery.cashHandover')
        || deliveryPermission(vendorId, 'delivery.cashReview');
    }

    function assignedDeliveryDriver(data) {
      return signedIn()
        && data.assignedDriverUid is string
        && data.assignedDriverUid == request.auth.uid
        && deliveryPermission(data.vendorId, 'delivery.track');
    }

    function customerTrackingTokenRead(data) {
      return signedIn()
        && data.customerTrackingTokenHash is string
        && request.auth.token.deliveryTrackingTokenHash == data.customerTrackingTokenHash;
    }

    function deliveryReadAllowed(data) {
      return isManager(data.vendorId)
        || deliveryPermission(data.vendorId, 'delivery.view')
        || assignedDeliveryDriver(data)
        || customerTrackingTokenRead(data);
    }

    function deliveryCompletedLimitedEdit() {
      return !deliveryStatusFinal(resource.data.status)
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'updatedAt',
          'reviewNotes',
          'internalReviewNote',
          'disputeStatus'
        ]);
    }

    function deliveryDocPath(deliveryId) {
      return /databases/$(database)/documents/deliveries/$(deliveryId);
    }

    function deliveryOpenForChild(data) {
      return data.deliveryId is string
        && exists(deliveryDocPath(data.deliveryId))
        && get(deliveryDocPath(data.deliveryId)).data.vendorId == data.vendorId
        && !deliveryStatusFinal(get(deliveryDocPath(data.deliveryId)).data.status);
    }

    function deliveryOpenForChildAfter(data) {
      return data.deliveryId is string
        && existsAfter(deliveryDocPath(data.deliveryId))
        && getAfter(deliveryDocPath(data.deliveryId)).data.vendorId == data.vendorId
        && !deliveryStatusFinal(getAfter(deliveryDocPath(data.deliveryId)).data.status);
    }

    function deliveryChildReadAllowed(data) {
      return data.deliveryId is string
        && exists(deliveryDocPath(data.deliveryId))
        && get(deliveryDocPath(data.deliveryId)).data.vendorId == data.vendorId
        && deliveryReadAllowed(get(deliveryDocPath(data.deliveryId)).data);
    }

    function deliveryCashHandoverAllowed(vendorId) {
      return deliveryPermission(vendorId, 'delivery.cashHandover')
        || deliveryPermission(vendorId, 'delivery.cashReview')
        || hasPermission(vendorId, 'cashControl.deliveryCash.confirm')
        || hasPermission(vendorId, 'cashControl.approve');
    }

    match /vendors/{vendorId} {
      allow create: if signedIn()
        && validId(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail is string
        && request.resource.data.ownerName is string
        && request.resource.data.businessName is string
        && request.resource.data.status == 'Active'
        && request.resource.data.planCode == 'DEMO'
        && request.resource.data.licenseStatus == 'DEMO'
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;

      allow get, list: if signedIn()
        && validId(vendorId)
        && (
          resource.data.ownerUid == request.auth.uid
          || resource.data.ownerEmail == signedInEmail()
          || isActiveVendorUser(vendorId)
        );

      allow update: if isOwner(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.ownerUid == resource.data.ownerUid;

      allow delete: if isOwner(vendorId);
    }

    // Canonical vendor-scoped purchasing domain. These collection names mirror
    // src/pos-new/firebase/firestorePaths.ts and intentionally coexist with the
    // legacy root collections during migration.
    match /vendors/{vendorId}/suppliers/{supplierId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.supplierId == supplierId
        && request.resource.data.supplierName is string
        && request.resource.data.supplierCode is string;
      allow update: if isActiveVendorUser(vendorId)
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == resource.data.vendorId
        && request.resource.data.supplierId == resource.data.supplierId;
      allow delete: if false;
    }

    match /vendors/{vendorId}/purchaseRequisitions/{requisitionId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.requisitionId == requisitionId
        && request.resource.data.status in ['Draft', 'Submitted'];
      allow update: if isActiveVendorUser(vendorId)
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == resource.data.vendorId
        && request.resource.data.requisitionId == resource.data.requisitionId
        && (
          request.resource.data.status == resource.data.status
          || (
            request.resource.data.status in ['Approved', 'Rejected']
            && isManager(vendorId)
          )
          || request.resource.data.status in ['Submitted', 'Converted', 'Cancelled']
        );
      allow delete: if false;
    }

    match /vendors/{vendorId}/purchaseRequisitionLines/{lineId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.lineId == lineId
        && request.resource.data.productId is string
        && request.resource.data.quantityRequested > 0;
      allow update, delete: if false;
    }

    match /vendors/{vendorId}/purchaseOrders/{poId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.poId == poId
        && request.resource.data.supplierId is string
        && request.resource.data.branchId is string
        && request.resource.data.warehouseId is string
        && request.resource.data.status == 'Draft';
      allow update: if isActiveVendorUser(vendorId)
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == resource.data.vendorId
        && request.resource.data.poId == resource.data.poId
        && request.resource.data.supplierId == resource.data.supplierId
        && request.resource.data.poNumber == resource.data.poNumber
        && (
          request.resource.data.status == resource.data.status
          || (
            request.resource.data.status == 'Approved'
            && isManager(vendorId)
          )
          || request.resource.data.status in ['Pending Approval', 'Sent To Supplier', 'Partially Received', 'Fully Received', 'Cancelled', 'Closed', 'Closed With Outstanding']
        );
      allow delete: if false;
    }

    match /vendors/{vendorId}/purchaseOrderLines/{lineId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.lineId == lineId
        && request.resource.data.poId is string
        && request.resource.data.productId is string
        && request.resource.data.qtyOrdered > 0
        && request.resource.data.estimatedUnitCost > 0;
      allow update: if isActiveVendorUser(vendorId)
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == resource.data.vendorId
        && request.resource.data.lineId == resource.data.lineId
        && request.resource.data.poId == resource.data.poId
        && request.resource.data.productId == resource.data.productId
        && request.resource.data.qtyOrdered == resource.data.qtyOrdered
        && request.resource.data.estimatedUnitCost == resource.data.estimatedUnitCost;
      allow delete: if false;
    }

    match /vendors/{vendorId}/goodsReceivingNotes/{grnId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.grnId == grnId
        && request.resource.data.supplierId is string
        && request.resource.data.branchId is string
        && request.resource.data.warehouseId is string
        && request.resource.data.receivingStatus in ['Draft', 'Pending Approval', 'Posted', 'Partially Posted'];
      allow update: if isActiveVendorUser(vendorId)
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == resource.data.vendorId
        && request.resource.data.grnId == resource.data.grnId
        && resource.data.postingStatus != 'Posted';
      allow delete: if false;
    }

    match /vendors/{vendorId}/goodsReceivingLines/{lineId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.lineId == lineId
        && request.resource.data.grnId is string
        && request.resource.data.productId is string;
      allow update: if isActiveVendorUser(vendorId)
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == resource.data.vendorId
        && request.resource.data.lineId == resource.data.lineId
        && request.resource.data.grnId == resource.data.grnId
        && request.resource.data.productId == resource.data.productId
        && request.resource.data.qtyAccepted == resource.data.qtyAccepted
        && request.resource.data.qtyAlreadyReturned >= resource.data.qtyAlreadyReturned
        && request.resource.data.qtyAlreadyReturned <= resource.data.qtyAccepted;
      allow delete: if false;
    }

    match /vendors/{vendorId}/supplierInvoices/{invoiceId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.invoiceId == invoiceId
        && request.resource.data.supplierId is string
        && request.resource.data.grandTotal > 0;
      allow update: if isActiveVendorUser(vendorId)
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == resource.data.vendorId
        && request.resource.data.invoiceId == resource.data.invoiceId
        && request.resource.data.supplierId == resource.data.supplierId
        && request.resource.data.supplierInvoiceNumber == resource.data.supplierInvoiceNumber
        && request.resource.data.grandTotal == resource.data.grandTotal
        && (
          request.resource.data.status == resource.data.status
          || (request.resource.data.status == 'Approved' && isManager(vendorId))
          || request.resource.data.status in ['PartiallyPaid', 'Paid', 'Disputed', 'Cancelled']
        );
      allow delete: if false;
    }

    match /vendors/{vendorId}/supplierInvoiceLines/{lineId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.lineId == lineId
        && request.resource.data.invoiceId is string;
      allow update, delete: if false;
    }

    match /vendors/{vendorId}/supplierPayments/{paymentId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.paymentId == paymentId
        && request.resource.data.supplierId is string
        && request.resource.data.invoiceId is string
        && request.resource.data.amount > 0
        && request.resource.data.status == 'POSTED';
      allow update, delete: if false;
    }

    match /vendors/{vendorId}/supplierPaymentReversals/{reversalId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isManager(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.reversalId == reversalId
        && request.resource.data.originalPaymentId is string
        && request.resource.data.reason is string
        && request.resource.data.correlationId is string
        && request.resource.data.idempotencyKey is string
        && request.resource.data.status == 'POSTED';
      allow update, delete: if false;
    }

    match /vendors/{vendorId}/supplierBalances/{supplierId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isManager(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.supplierId == supplierId
        && request.resource.data.version == 1;
      allow update: if isManager(vendorId)
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == resource.data.vendorId
        && request.resource.data.supplierId == resource.data.supplierId
        && request.resource.data.version == resource.data.version + 1;
      allow delete: if false;
    }

    match /vendors/{vendorId}/mutationReceipts/{idempotencyKey} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isManager(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.receiptDocumentId == idempotencyKey
        && request.resource.data.idempotencyKey is string
        && request.resource.data.operation is string
        && request.resource.data.entityId is string
        && request.resource.data.correlationId is string
        && request.resource.data.requestFingerprint is string
        && request.resource.data.status == 'completed';
      allow update, delete: if false;
    }

    match /vendors/{vendorId}/supplierReturns/{supplierReturnId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.supplierReturnId == supplierReturnId
        && request.resource.data.supplierId is string
        && request.resource.data.grnId is string;
      allow update: if isActiveVendorUser(vendorId)
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == resource.data.vendorId
        && request.resource.data.supplierReturnId == resource.data.supplierReturnId
        && resource.data.status != 'Posted';
      allow delete: if false;
    }

    match /vendors/{vendorId}/supplierReturnLines/{lineId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.lineId == lineId
        && request.resource.data.supplierReturnId is string
        && request.resource.data.productId is string
        && request.resource.data.qtyReturnApproved > 0;
      allow update, delete: if false;
    }

    match /vendors/{vendorId}/supplierCreditNotes/{creditNoteId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.creditNoteId == creditNoteId
        && request.resource.data.supplierId is string;
      allow update, delete: if false;
    }

    // Build 09.1C migration control-plane. Only the vendor owner may mutate it;
    // completed history, approved fingerprints, and successful results are sealed.
    match /vendors/{vendorId}/purchasingMigrationRuns/{migrationRunId} {
      allow read: if isManager(vendorId);
      allow create: if isOwner(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.migrationRunId == migrationRunId
        && request.resource.data.status in ['draft', 'previewed'];
      allow update: if isOwner(vendorId)
        && resource.data.vendorId == vendorId
        && request.resource.data.vendorId == resource.data.vendorId
        && request.resource.data.migrationRunId == resource.data.migrationRunId
        && request.resource.data.sourceFingerprint == resource.data.sourceFingerprint
        && (!(resource.data.status in ['approved', 'running', 'partiallyCompleted'])
          || (request.resource.data.approvedBy == resource.data.approvedBy
            && request.resource.data.acknowledgedWarnings == resource.data.acknowledgedWarnings))
        && resource.data.status != 'completed';
      allow delete: if isOwner(vendorId) && resource.data.status in ['draft', 'previewed', 'cancelled'];

      match /records/{recordId} {
        allow read: if isManager(vendorId);
        allow create: if isOwner(vendorId) && request.resource.data.vendorId == vendorId;
        allow update: if isOwner(vendorId)
          && request.resource.data.vendorId == resource.data.vendorId
          && request.resource.data.sourceFingerprint == resource.data.sourceFingerprint
          && request.resource.data.legacySourceType == resource.data.legacySourceType
          && request.resource.data.legacyRecordId == resource.data.legacyRecordId
          && request.resource.data.destinationId == resource.data.destinationId
          && request.resource.data.migrationRunId == resource.data.migrationRunId
          && resource.data.status != 'migrated';
        allow delete: if false;
      }
      match /issues/{issueId} {
        allow read: if isManager(vendorId);
        allow create, update: if isOwner(vendorId) && request.resource.data.vendorId == vendorId;
        allow delete: if false;
      }
      match /reconciliations/{reconciliationId} {
        allow read: if isManager(vendorId);
        allow create: if isOwner(vendorId) && request.resource.data.vendorId == vendorId;
        allow update: if isOwner(vendorId)
          && request.resource.data.vendorId == resource.data.vendorId
          && resource.data.completed != true;
        allow delete: if false;
      }
    }

    // Shared records written in the same atomic purchasing transactions.
    match /vendors/{vendorId}/productMaster/{productId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create, update: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.productId == productId;
      allow delete: if false;
    }

    match /vendors/{vendorId}/productStockBalances/{balanceId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create, update: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.balanceId == balanceId
        && request.resource.data.productId is string;
      allow delete: if false;
    }

    match /vendors/{vendorId}/inventoryMovements/{movementId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.movementId == movementId
        && request.resource.data.productId is string
        && request.resource.data.branchId is string
        && request.resource.data.warehouseId is string
        && request.resource.data.sourceType is string
        && request.resource.data.sourceId is string
        && request.resource.data.sourceLineId is string
        && request.resource.data.correlationId is string
        && request.resource.data.idempotencyKey is string
        && request.resource.data.postedBy is string
        && request.resource.data.postedAt is timestamp
        && request.resource.data.openingBalance is number
        && request.resource.data.quantityDelta is number
        && request.resource.data.closingBalance is number
        && request.resource.data.openingBalance + request.resource.data.quantityDelta == request.resource.data.closingBalance
        && request.resource.data.movementType in ['GOODS_RECEIVED', 'SUPPLIER_RETURN'];
      allow update, delete: if false;
    }

    match /vendors/{vendorId}/pos_cash_movements/{movementId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.movementId == movementId
        && request.resource.data.amount > 0;
      allow update, delete: if false;
    }

    match /vendors/{vendorId}/biEvents/{eventId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && request.resource.data.eventId == eventId;
      allow update, delete: if false;
    }

    match /vendors/{vendorId}/audit_logs/{auditId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if isActiveVendorUser(vendorId)
        && request.resource.data.vendorId == vendorId
        && (request.resource.data.auditId == auditId || request.resource.data.auditLogId == auditId);
      allow update, delete: if false;
    }

    match /vendorUsers/{uid} {
      allow get: if signedIn()
        && uid == request.auth.uid
        && activeMemberStatus(resource.data.status);

      allow list: if false;

      allow create: if signedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.vendorId is string
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.role == 'Owner'
        && request.resource.data.status == 'active'
        && request.resource.data.permissions is list
        && request.resource.data.permissions.size() == 1
        && request.resource.data.permissions[0] == '*'
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && ownerFromVendorDocAfter(request.resource.data.vendorId);

      allow update: if signedIn()
        && request.resource.data.vendorId == resource.data.vendorId
        && (
          uid == request.auth.uid
          || isOwner(resource.data.vendorId)
        );

      allow delete: if signedIn() && isOwner(resource.data.vendorId);
    }

    match /branches/{branchId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if canManageCreatedVendor(request.resource.data.vendorId)
        && request.resource.data.vendorId is string
        && request.resource.data.branchId == branchId;
      allow update: if isManager(resource.data.vendorId)
        && request.resource.data.vendorId == resource.data.vendorId;
      allow delete: if isOwner(resource.data.vendorId);
    }

    match /warehouses/{warehouseId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if canManageCreatedVendor(request.resource.data.vendorId)
        && request.resource.data.vendorId is string
        && request.resource.data.warehouseId == warehouseId;
      allow update: if isManager(resource.data.vendorId)
        && request.resource.data.vendorId == resource.data.vendorId;
      allow delete: if isOwner(resource.data.vendorId);
    }

    match /staff/{staffId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if canManageCreatedVendor(request.resource.data.vendorId)
        && request.resource.data.vendorId is string
        && request.resource.data.staffId == staffId;
      allow update: if isManager(resource.data.vendorId)
        && request.resource.data.vendorId == resource.data.vendorId;
      allow delete: if isOwner(resource.data.vendorId);
    }

    match /pos_terminals/{terminalId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if canManageCreatedVendor(request.resource.data.vendorId)
        && request.resource.data.vendorId is string
        && request.resource.data.terminalId == terminalId;
      allow update: if isManager(resource.data.vendorId)
        && request.resource.data.vendorId == resource.data.vendorId;
      allow delete: if isOwner(resource.data.vendorId);
    }

    match /licenses/{licenseId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if canManageCreatedVendor(request.resource.data.vendorId)
        && request.resource.data.vendorId is string
        && request.resource.data.licenseId == licenseId;
      allow update: if isOwner(resource.data.vendorId)
        && request.resource.data.vendorId == resource.data.vendorId;
      allow delete: if isOwner(resource.data.vendorId);
    }

    match /vendor_settings/{vendorId} {
      allow read: if isActiveVendorUser(vendorId);
      allow create: if canManageCreatedVendor(vendorId)
        && request.resource.data.vendorId == vendorId;
      allow update: if isOwner(vendorId)
        && request.resource.data.vendorId == vendorId;
      allow delete: if isOwner(vendorId);
    }

    match /customers/{customerId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.customerId == customerId
        && request.resource.data.customerName is string
        && request.resource.data.customerType in ['WalkIn', 'Individual', 'Business', 'Government', 'Staff', 'Other']
        && request.resource.data.status in ['Active', 'Inactive', 'Pending Approval', 'Duplicate', 'Suspended']
        && request.resource.data.currentBalance == 0
        && request.resource.data.overdueBalance == 0;
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.currentBalance == resource.data.currentBalance
        && request.resource.data.overdueBalance == resource.data.overdueBalance
        && (
          request.resource.data.creditStatus == resource.data.creditStatus
          || customerCreditApprovalAllowed(resource.data.vendorId)
          || customerCreditBlockAllowed(resource.data.vendorId)
        );
      allow delete: if false;
    }

    match /customer_credit_applications/{creditApplicationId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && customerCreditApplicationIdMatches(creditApplicationId, request.resource.data)
        && request.resource.data.customerId is string
        && (
          request.resource.data.requestedLimit > 0
          || request.resource.data.requestedCreditLimit > 0
        )
        && (
          request.resource.data.requestedTermsDays > 0
          || request.resource.data.requestedPaymentTermsDays > 0
        )
        && request.resource.data.status in ['Draft', 'Submitted', 'UnderReview', 'PendingReview', 'Approved', 'Rejected', 'Suspended', 'Expired'];
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && customerCreditApplicationIdMatches(creditApplicationId, request.resource.data)
        && customerCreditApplicationIdMatches(creditApplicationId, resource.data)
        && request.resource.data.customerId == resource.data.customerId
        && (
          request.resource.data.status == resource.data.status
          || (
            request.resource.data.status in ['Approved', 'Rejected', 'Suspended']
            && customerCreditApprovalAllowed(resource.data.vendorId)
          )
          || request.resource.data.status in ['Draft', 'Submitted', 'UnderReview', 'PendingReview', 'Expired']
        );
      allow delete: if false;
    }

    match /customer_accounts/{entryId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.entryId == entryId
        && request.resource.data.customerId is string
        && request.resource.data.branchId is string
        && request.resource.data.entryType in ['CREDIT_SALE', 'PAYMENT', 'CREDIT_NOTE', 'SALES_RETURN', 'OPENING_BALANCE', 'ADJUSTMENT', 'INTEREST', 'WRITE_OFF', 'REVERSAL']
        && request.resource.data.referenceType is string
        && request.resource.data.referenceId is string
        && request.resource.data.debit >= 0
        && request.resource.data.credit >= 0
        && request.resource.data.debit + request.resource.data.credit > 0;
      allow update, delete: if false;
    }

    match /customer_payments/{customerPaymentId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && customerPaymentIdMatches(customerPaymentId, request.resource.data)
        && request.resource.data.customerId is string
        && request.resource.data.branchId is string
        && request.resource.data.terminalId is string
        && request.resource.data.amount > 0
        && request.resource.data.paymentMethod in ['Cash', 'Mobile Money', 'Card', 'Bank Transfer', 'Other'];
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && customerPaymentIdMatches(customerPaymentId, request.resource.data)
        && customerPaymentIdMatches(customerPaymentId, resource.data)
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.amount == resource.data.amount
        && postedPaymentMutable();
      allow delete: if false;
    }

    match /customer_payment_allocations/{allocationId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.allocationId == allocationId
        && request.resource.data.customerPaymentId is string
        && request.resource.data.customerId is string
        && request.resource.data.accountEntryId is string
        && request.resource.data.amountAllocated > 0;
      allow update, delete: if false;
    }

    match /customer_statements/{statementId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.statementId == statementId
        && request.resource.data.customerId is string
        && request.resource.data.status in ['Draft', 'Issued', 'PreparedToSend', 'Cancelled'];
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.statementId == resource.data.statementId
        && request.resource.data.customerId == resource.data.customerId
        && statementSnapshotMutable();
      allow delete: if false;
    }

    match /customer_collection_actions/{collectionActionId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.collectionActionId == collectionActionId
        && request.resource.data.customerId is string
        && request.resource.data.actionType in ['PHONE_CALL', 'WHATSAPP', 'EMAIL', 'VISIT', 'REMINDER', 'PROMISE_TO_PAY', 'DISPUTE', 'ESCALATION', 'CREDIT_BLOCK', 'WRITE_OFF_REVIEW']
        && (
          request.resource.data.actionType != 'CREDIT_BLOCK'
          || customerCreditBlockAllowed(request.resource.data.vendorId)
        );
      allow update, delete: if false;
    }

    match /customer_promises/{promiseId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.promiseId == promiseId
        && request.resource.data.customerId is string
        && request.resource.data.promisedAmount > 0
        && request.resource.data.promiseDate is string
        && request.resource.data.status in ['Active', 'PartiallyFulfilled', 'Fulfilled', 'Broken', 'Cancelled'];
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.promiseId == resource.data.promiseId
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.promisedAmount == resource.data.promisedAmount;
      allow delete: if false;
    }

    match /customer_disputes/{disputeId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.disputeId == disputeId
        && request.resource.data.customerId is string
        && request.resource.data.referenceId is string
        && request.resource.data.disputedAmount > 0
        && request.resource.data.status in ['Open', 'UnderReview', 'Resolved', 'Rejected', 'Escalated'];
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.disputeId == resource.data.disputeId
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.disputedAmount == resource.data.disputedAmount
        && (
          request.resource.data.status == resource.data.status
          || customerAdjustmentAllowed(resource.data.vendorId)
        );
      allow delete: if false;
    }

    match /customer_credit_notes/{creditNoteId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.creditNoteId == creditNoteId
        && request.resource.data.customerId is string
        && request.resource.data.referenceSaleId is string
        && request.resource.data.amount > 0
        && request.resource.data.vatAmount >= 0
        && request.resource.data.status in ['Draft', 'Approved', 'Posted', 'Cancelled', 'Reversed']
        && (
          request.resource.data.status == 'Draft'
          || customerAdjustmentAllowed(request.resource.data.vendorId)
        );
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.creditNoteId == resource.data.creditNoteId
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.amount == resource.data.amount
        && (
          request.resource.data.status == resource.data.status
          || customerAdjustmentAllowed(resource.data.vendorId)
        );
      allow delete: if false;
    }

    match /customer_writeoffs/{writeOffId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.writeOffId == writeOffId
        && request.resource.data.customerId is string
        && request.resource.data.amount > 0
        && request.resource.data.reason is string
        && request.resource.data.status in ['Requested', 'Approved', 'Posted', 'Rejected']
        && customerWriteOffAllowed(request.resource.data.vendorId);
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.writeOffId == resource.data.writeOffId
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.amount == resource.data.amount
        && customerWriteOffAllowed(resource.data.vendorId);
      allow delete: if false;
    }

    match /pos_sales/{saleId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendor(request.resource.data.vendorId)
        && request.resource.data.saleId == saleId
        && request.resource.data.branchId is string
        && request.resource.data.warehouseId is string
        && request.resource.data.terminalId is string
        && request.resource.data.staffId is string;
      allow update: if updateForSameVendor(resource.data.vendorId)
        && request.resource.data.saleId == resource.data.saleId
        && request.resource.data.staffId == resource.data.staffId
        && (
          resource.data.saleStatus != 'Completed'
          || (
            request.resource.data.subtotal == resource.data.subtotal
            && request.resource.data.discountTotal == resource.data.discountTotal
            && request.resource.data.taxableAmount == resource.data.taxableAmount
            && request.resource.data.vatTotal == resource.data.vatTotal
            && request.resource.data.grandTotal == resource.data.grandTotal
            && request.resource.data.amountPaid == resource.data.amountPaid
            && request.resource.data.balanceDue == resource.data.balanceDue
            && request.resource.data.saleStatus == resource.data.saleStatus
          )
        );
      allow delete: if false;
    }

    match /pos_sale_items/{saleLineId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendor(request.resource.data.vendorId)
        && request.resource.data.saleLineId == saleLineId
        && request.resource.data.saleId is string
        && request.resource.data.productId is string
        && request.resource.data.branchId is string
        && request.resource.data.warehouseId is string;
      allow update, delete: if false;
    }

    match /pos_payments/{paymentId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendor(request.resource.data.vendorId)
        && request.resource.data.paymentId == paymentId
        && request.resource.data.saleId is string
        && request.resource.data.branchId is string
        && request.resource.data.terminalId is string
        && request.resource.data.staffId is string;
      allow update, delete: if false;
    }

    match /deliveries/{deliveryId} {
      allow read: if resource.data.vendorId is string
        && deliveryReadAllowed(resource.data);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.deliveryId == deliveryId
        && request.resource.data.branchId is string
        && request.resource.data.warehouseId is string
        && request.resource.data.terminalId is string
        && request.resource.data.createdBy is string
        && request.resource.data.customerName is string
        && request.resource.data.deliveryAddress is string
        && request.resource.data.status in ['Draft', 'AwaitingAssignment', 'Assigned', 'ReadyForDispatch', 'Dispatched', 'InTransit', 'Arrived', 'PartiallyDelivered', 'Delivered', 'DeliveryFailed', 'Cancelled', 'AwaitingCustomerConfirmation', 'AwaitingCashHandover', 'Completed', 'Disputed']
        && deliveryMutationAllowed(request.resource.data.vendorId);
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.deliveryId == resource.data.deliveryId
        && request.resource.data.vendorId == resource.data.vendorId
        && deliveryMutationAllowed(resource.data.vendorId)
        && deliveryCompletedLimitedEdit();
      allow delete: if false;
    }

    match /delivery_lines/{deliveryLineId} {
      allow read: if deliveryChildReadAllowed(resource.data);
      allow create: if createForVendor(request.resource.data.vendorId)
        && (request.resource.data.deliveryLineId == deliveryLineId || request.resource.data.lineId == deliveryLineId)
        && request.resource.data.productId is string
        && request.resource.data.quantityOrdered > 0
        && request.resource.data.quantityDispatched <= request.resource.data.quantityOrdered
        && request.resource.data.quantityDelivered <= request.resource.data.quantityDispatched
        && deliveryMutationAllowed(request.resource.data.vendorId)
        && deliveryOpenForChildAfter(request.resource.data);
      allow update: if updateForSameVendor(resource.data.vendorId)
        && request.resource.data.vendorId == resource.data.vendorId
        && (request.resource.data.deliveryLineId == resource.data.deliveryLineId || request.resource.data.lineId == resource.data.lineId)
        && request.resource.data.quantityDispatched <= request.resource.data.quantityOrdered
        && request.resource.data.quantityDelivered + request.resource.data.quantityRejected <= request.resource.data.quantityDispatched
        && deliveryMutationAllowed(resource.data.vendorId)
        && deliveryOpenForChild(resource.data);
      allow delete: if false;
    }

    match /delivery_addresses/{addressId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendor(request.resource.data.vendorId)
        && request.resource.data.addressId == addressId
        && request.resource.data.customerId is string
        && request.resource.data.addressLine is string
        && request.resource.data.contactPhone is string
        && deliveryPermission(request.resource.data.vendorId, 'delivery.create');
      allow update: if updateForSameVendor(resource.data.vendorId)
        && request.resource.data.addressId == resource.data.addressId
        && request.resource.data.customerId == resource.data.customerId
        && deliveryPermission(resource.data.vendorId, 'delivery.create');
      allow delete: if false;
    }

    match /delivery_assignments/{assignmentId} {
