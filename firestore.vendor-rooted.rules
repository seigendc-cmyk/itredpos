      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.goodsReceiptLineId == resource.data.goodsReceiptLineId
        && (
          !exists(/databases/$(database)/documents/goods_receipts/$(resource.data.goodsReceiptId))
