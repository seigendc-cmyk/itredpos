        && request.resource.data.supplierId is string
        && returnReferencesAccessibleReceipt(request.resource.data);
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.purchaseReturnId == resource.data.purchaseReturnId
        && returnReferencesAccessibleReceipt(request.resource.data)
        && (
          request.resource.data.approvalStatus == resource.data.approvalStatus
          || hasPermission(resource.data.vendorId, 'approvals.approve')
          || hasPermission(resource.data.vendorId, 'supplierReturns.approve')
        );
      allow delete: if false;
    }

    match /purchase_return_lines/{purchaseReturnLineId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.purchaseReturnLineId == purchaseReturnLineId
        && request.resource.data.purchaseReturnId is string
        && request.resource.data.goodsReceiptLineId is string
        && request.resource.data.quantityReturned >= 0;
      allow update, delete: if false;
    }

    match /supplier_accounts/{entryId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.entryId == entryId
        && request.resource.data.supplierId is string
        && request.resource.data.branchId is string
        && request.resource.data.entryType in ['PURCHASE', 'PAYMENT', 'PURCHASE_RETURN', 'CREDIT_NOTE', 'DEBIT_NOTE', 'OPENING_BALANCE', 'ADJUSTMENT', 'INTEREST', 'REVERSAL']
        && request.resource.data.referenceType is string
        && request.resource.data.referenceId is string
        && request.resource.data.debit >= 0
        && request.resource.data.credit >= 0
        && request.resource.data.debit + request.resource.data.credit > 0;
      allow update, delete: if false;
    }

    match /supplier_payments/{supplierPaymentId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && supplierPaymentIdMatches(supplierPaymentId, request.resource.data)
        && request.resource.data.supplierId is string
        && request.resource.data.branchId is string
        && request.resource.data.terminalId is string
        && request.resource.data.amount > 0
        && request.resource.data.paymentMethod in ['Cash', 'Bank', 'Mobile Money', 'Other', 'Bank Transfer', 'COGS Reserve']
        && supplierPaymentAllowed(request.resource.data.vendorId);
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && supplierPaymentIdMatches(supplierPaymentId, request.resource.data)
        && supplierPaymentIdMatches(supplierPaymentId, resource.data)
        && request.resource.data.supplierId == resource.data.supplierId
        && request.resource.data.amount == resource.data.amount
        && supplierPaymentMutable()
        && (
          request.resource.data.approvalStatus == resource.data.approvalStatus
          || supplierPaymentApprovalAllowed(resource.data.vendorId)
        );
      allow delete: if false;
    }

    match /supplier_payment_allocations/{allocationId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.allocationId == allocationId
        && request.resource.data.supplierPaymentId is string
        && request.resource.data.supplierId is string
        && request.resource.data.supplierAccountEntryId is string
        && request.resource.data.amountAllocated > 0;
      allow update, delete: if false;
    }

    match /supplier_payment_schedules/{scheduleId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.scheduleId == scheduleId
        && request.resource.data.supplierId is string
        && request.resource.data.scheduledAmount > 0
        && request.resource.data.priority in ['Critical', 'High', 'Normal', 'Low']
        && request.resource.data.status in ['Draft', 'Planned', 'PendingApproval', 'Approved', 'PartiallyPaid', 'Paid', 'Deferred', 'Cancelled'];
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.scheduleId == resource.data.scheduleId
        && request.resource.data.supplierId == resource.data.supplierId
        && request.resource.data.scheduledAmount == resource.data.scheduledAmount
        && (
          request.resource.data.status == resource.data.status
          || supplierPaymentApprovalAllowed(resource.data.vendorId)
          || request.resource.data.status in ['Deferred', 'Cancelled']
        );
      allow delete: if false;
    }

    match /supplier_statements/{statementId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.statementId == statementId
        && request.resource.data.supplierId is string
        && request.resource.data.status in ['Draft', 'Issued', 'Reconciled', 'Cancelled'];
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.statementId == resource.data.statementId
        && request.resource.data.supplierId == resource.data.supplierId
        && resource.data.status != 'Reconciled';
      allow delete: if false;
    }

    match /supplier_reconciliations/{reconciliationId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.reconciliationId == reconciliationId
        && request.resource.data.supplierId is string
        && request.resource.data.status in ['Draft', 'DifferenceFound', 'UnderReview', 'Reconciled', 'Approved', 'Reopened'];
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.reconciliationId == resource.data.reconciliationId
        && request.resource.data.supplierId == resource.data.supplierId
        && supplierReconciliationMutable()
        && (
          request.resource.data.status == resource.data.status
          || supplierAdjustmentAllowed(resource.data.vendorId)
        );
      allow delete: if false;
    }

    match /supplier_credit_notes/{supplierCreditNoteId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.supplierCreditNoteId == supplierCreditNoteId
        && request.resource.data.supplierId is string
        && request.resource.data.amount > 0
        && request.resource.data.vatAmount >= 0
        && request.resource.data.status in ['Draft', 'Approved', 'Posted', 'Cancelled', 'Reversed']
        && (
          request.resource.data.status == 'Draft'
          || supplierAdjustmentAllowed(request.resource.data.vendorId)
        );
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.supplierCreditNoteId == resource.data.supplierCreditNoteId
        && request.resource.data.supplierId == resource.data.supplierId
        && request.resource.data.amount == resource.data.amount
        && (
          request.resource.data.status == resource.data.status
          || supplierAdjustmentAllowed(resource.data.vendorId)
        );
      allow delete: if false;
    }

    match /supplier_debit_notes/{debitNoteId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.debitNoteId == debitNoteId
        && request.resource.data.supplierId is string
        && request.resource.data.amount > 0
        && request.resource.data.vatAmount >= 0
        && request.resource.data.status in ['Draft', 'Approved', 'Posted', 'Cancelled', 'Reversed']
        && (
          request.resource.data.status == 'Draft'
          || supplierAdjustmentAllowed(request.resource.data.vendorId)
        );
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.debitNoteId == resource.data.debitNoteId
        && request.resource.data.supplierId == resource.data.supplierId
        && request.resource.data.amount == resource.data.amount
        && (
          request.resource.data.status == resource.data.status
          || supplierAdjustmentAllowed(resource.data.vendorId)
        );
      allow delete: if false;
    }

    match /supplier_disputes/{disputeId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.disputeId == disputeId
        && request.resource.data.supplierId is string
        && request.resource.data.referenceId is string
        && request.resource.data.disputedAmount > 0
        && request.resource.data.status in ['Open', 'UnderReview', 'Resolved', 'Rejected', 'Escalated'];
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.disputeId == resource.data.disputeId
        && request.resource.data.supplierId == resource.data.supplierId
        && request.resource.data.disputedAmount == resource.data.disputedAmount
        && (
          request.resource.data.status == resource.data.status
          || supplierAdjustmentAllowed(resource.data.vendorId)
        );
      allow delete: if false;
    }

    match /approval_requests/{approvalId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.approvalId == approvalId
        && request.resource.data.referenceId is string
        && request.resource.data.requestType is string;
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.approvalId == resource.data.approvalId
        && (
          request.resource.data.status == resource.data.status
          || hasPermission(resource.data.vendorId, 'approvals.approve')
        );
      allow delete: if false;
    }

    match /stock_transfers/{transferId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.transferId == transferId
        && request.resource.data.sourceBranchId is string
        && request.resource.data.sourceWarehouseId is string
        && request.resource.data.destinationBranchId is string
        && request.resource.data.destinationWarehouseId is string
        && request.resource.data.sourceWarehouseId != request.resource.data.destinationWarehouseId;
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.transferId == resource.data.transferId
        && transferEditable();
      allow delete: if false;
    }

    match /stock_transfer_lines/{transferLineId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.transferLineId == transferLineId
        && request.resource.data.transferId is string
        && request.resource.data.productId is string
        && request.resource.data.quantityRequested > 0;
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.transferLineId == resource.data.transferLineId
        && request.resource.data.quantityReceived <= request.resource.data.quantityDispatched;
      allow delete: if false;
    }

    match /stocktakes/{stocktakeId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.stocktakeId == stocktakeId
        && request.resource.data.branchId is string
        && request.resource.data.warehouseId is string;
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.stocktakeId == resource.data.stocktakeId
        && stocktakeEditable();
      allow delete: if false;
    }

    match /stocktake_lines/{stocktakeLineId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.stocktakeLineId == stocktakeLineId
        && request.resource.data.stocktakeId is string
        && request.resource.data.productId is string
        && request.resource.data.expectedQty is number;
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.stocktakeLineId == resource.data.stocktakeLineId
        && !(resource.data.status in ['Posted', 'Closed']);
      allow delete: if false;
    }

    match /stock_adjustments/{adjustmentId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.adjustmentId == adjustmentId
        && request.resource.data.branchId is string
        && request.resource.data.warehouseId is string
        && request.resource.data.reason is string
        && highRiskAdjustmentAllowed(request.resource.data.vendorId, request.resource.data);
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.adjustmentId == resource.data.adjustmentId
        && highRiskAdjustmentAllowed(resource.data.vendorId, request.resource.data);
      allow delete: if false;
    }

    match /stock_losses/{lossId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.lossId == lossId
        && request.resource.data.branchId is string
        && request.resource.data.warehouseId is string
        && request.resource.data.productId is string
        && request.resource.data.quantity > 0
        && request.resource.data.reason is string;
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.lossId == resource.data.lossId
        && (
          request.resource.data.approvalStatus == resource.data.approvalStatus
          || hasPermission(resource.data.vendorId, 'inventory.loss.approve')
          || hasPermission(resource.data.vendorId, 'approvals.approve')
        );
      allow delete: if false;
    }

    match /stock_reservations/{reservationId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.reservationId == reservationId
        && request.resource.data.branchId is string
        && request.resource.data.warehouseId is string
        && request.resource.data.productId is string
        && request.resource.data.quantityReserved > 0;
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.reservationId == resource.data.reservationId
        && request.resource.data.quantityReserved == resource.data.quantityReserved;
      allow delete: if false;
    }

    match /reorder_recommendations/{recommendationId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create, update: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.recommendationId == recommendationId
        && request.resource.data.warehouseId is string
        && request.resource.data.productId is string;
      allow delete: if false;
    }

    match /inventory_reconciliations/{reconciliationId} {
      allow read: if isActiveVendorUser(resource.data.vendorId);
      allow create: if createForVendorStaff(request.resource.data.vendorId)
        && request.resource.data.reconciliationId == reconciliationId
        && request.resource.data.warehouseId is string
        && request.resource.data.productId is string;
      allow update: if updateForSameVendorStaff(resource.data.vendorId)
        && request.resource.data.reconciliationId == resource.data.reconciliationId
        && balanceRebuildAllowed(resource.data.vendorId);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
